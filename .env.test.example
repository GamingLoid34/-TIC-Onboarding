# Testmiljö – kopiera till .env.test och fyll i från ett SEPARAT Supabase-projekt (test)
# Skapa t.ex. "Ötic Onboarding Test" i Supabase och använd dess Connection strings.
# Använd aldrig produktionsdatabasen i testmiljön.

# Pooler (Transaction) – för appen i test
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection – för db push och seed i test
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
