# Supabase (PostgreSQL + Auth)
# Project Settings → API: Project URL och anon public key (för inloggning).
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"
# Service Role Key (Project Settings → API → service_role). Endast för server: skapa användare med lösenord under Admin. Exponera ALDRIG i klienten.
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"

# Database: Project Settings → Database → Connection string (URI)

# App (pooler, port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# db push / migreringar: MÅSTE vara "Direct connection" från Supabase.
# I Supabase: Database → Connection string → välj "Direct connection" → kopiera URI.
# Värd ska vara: db.[PROJECT-REF].supabase.co (INTE pooler.supabase.com).
# Användare: postgres. Lösenord: samma som "Database password" i samma flik.
# Fel DIRECT_URL ger: "Tenant or user not found" eller "Authentication failed".
# P1001 "Can't reach database server"? Prova Session-pooler nedan (port 6543) för DIRECT_URL.
# Lägg till timeout så att db push inte hänger: ?connect_timeout=10&statement_timeout=60000
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?connect_timeout=10&statement_timeout=60000"

# Alternativ om port 5432 blockeras: använd pooler (port 6543). db push kan då hänga – se README.
# Supabase → Connection string → Session (eller Transaction) – byt port till 5432 i pooler-URL:en
# eller använd samma pooler-värd med port 6543 (kan fungera för db push på vissa nät).
# DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
